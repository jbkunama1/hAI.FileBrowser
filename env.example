# Config-Verzeichnis von File Browser
FB_CONFIG_PATH=/srv/filebrowser/config

# Eingebundene Verzeichnisse (Host-Pfad)
FB_DATA_ALLGEMEIN=/srv/filebrowser/data
FB_DATA_DOKUMENTE=/mnt/nas/dokumente
FB_DATA_FOTOS=/mnt/nas/fotos
FB_DATA_PROJEKTE=/home/daniel/projekte

# Login-Zugangsdaten (Pflicht - Standard admin/admin NICHT verwenden!)
FB_USERNAME=daniel
FB_PASSWORD=BITTE_SICHERES_PASSWORT_EINTRAGEN

# Optional: UID/GID des Host-Nutzers (falls Rechteprobleme auftreten)
# FB_UID=1000
# FB_GID=1000
